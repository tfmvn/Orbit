# Copy to .env and adjust for local development.

ORBIT_APP_NAME=orbit-api
ORBIT_ENVIRONMENT=local

ORBIT_HOST=0.0.0.0
ORBIT_PORT=8000

ORBIT_CORS_ALLOW_ORIGINS=["http://localhost:3000"]

ORBIT_LOG_LEVEL=INFO
ORBIT_LOG_JSON=false

# Filesystem tool operations are sandboxed to this directory.
ORBIT_WORKSPACE_ROOT=./workspace

# Model Provider system — Ollama provider (see packages/providers).
ORBIT_OLLAMA_BASE_URL=http://localhost:11434
ORBIT_OLLAMA_DEFAULT_MODEL=llama3
ORBIT_OLLAMA_TIMEOUT=60.0
